# Postgres connection string.
# In the Docker Compose stack the DB host is the `postgres` service name.
# If you run the app directly on your host instead, use `localhost` as the host.
DATABASE_URI=postgresql://customs:customs@postgres:5432/customs

# Any long random string (>= 32 chars). Used to sign/encrypt Payload auth.
PAYLOAD_SECRET=change_me_to_a_long_random_string_min_32_chars
