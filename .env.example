# Postgres connection string.
# In the Docker Compose stack the DB host is the `postgres` service name.
# If you run the app directly on your host instead, use `localhost` as the host.
DATABASE_URI=postgresql://customs:customs@postgres:5432/customs

# Any long random string (>= 32 chars). Used to sign/encrypt Payload auth.
PAYLOAD_SECRET=change_me_to_a_long_random_string_min_32_chars

# Gemini API key for AI features (estimator + invoice ingestion). Server-side only.
GEMINI_API_KEY=

# Canonical public URL — used for SEO (sitemap, canonical tags, JSON-LD, OG images).
NEXT_PUBLIC_SITE_URL=https://120customs.com

# Resend — contact-form email notifications.
RESEND_API_KEY=
# Sender. Use 'onboarding@resend.dev' until your domain is verified in Resend.
RESEND_FROM=120 Customs <onboarding@resend.dev>
# Where inquiry notifications are sent (must be your Resend account email until domain verified).
INQUIRY_NOTIFY_EMAIL=

# DigitalOcean Spaces (S3-compatible) — media storage. When S3_BUCKET is set, Payload
# stores uploads in Spaces; otherwise it falls back to local disk (dev).
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Only needed to re-run scripts/export-legacy-firestore.mjs (legacy data migration).
# FIREBASE_API_KEY=
